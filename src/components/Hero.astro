---
import { site } from "../data/site";
---

<section class="section-padding bg-gradient-to-b from-[var(--color-accent-light)] to-[var(--color-bg)]">
  <div class="container-main">
    <div class="max-w-3xl">
      <p class="badge mb-4">2026 guide</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[var(--color-text)] leading-tight">
        How to Take Payments Without a Card Reader
      </h1>
      <p class="mt-5 text-xl prose-muted leading-relaxed">
        No terminal, no hardware, no customer app — here's how to accept payments on-site and get paid the moment the job's done.
      </p>
      <p class="mt-4 text-base prose-muted">
        If you're searching for ways to <strong class="font-medium text-[var(--color-text)]">take payments without a card reader</strong>, you're not alone. Mobile service businesses, event vendors, and solo operators need to get paid in the field — without buying, charging, or carrying a card reader.
      </p>
      <div class="mt-8">
        <a href={site.valetfyUrl} class="btn-primary text-lg" rel="noopener">
          See how Valetfy works →
        </a>
      </div>
    </div>
  </div>
</section>
