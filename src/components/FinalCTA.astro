---
import { site } from "../data/site";
---

<section class="section-padding bg-[var(--color-accent-light)]" aria-labelledby="cta-heading">
  <div class="container-main text-center max-w-2xl mx-auto">
    <h2 id="cta-heading" class="text-3xl font-bold tracking-tight text-[var(--color-text)]">
      Ready to skip the card reader?
    </h2>
    <p class="mt-4 text-lg prose-muted">
      If in-person, hardware-free payments fit your workflow, explore Valetfy — designed for Apple Wallet QR checkout with no terminal and no customer app download.
    </p>
    <div class="mt-8">
      <a href={site.valetfyUrl} class="btn-primary text-lg" rel="noopener">
        Explore Valetfy for hardware-free payments →
      </a>
    </div>
  </div>
</section>
