---
import { howItWorksSteps } from "../data/payment-methods";
---

<section id="how-it-works" class="section-padding bg-[var(--color-bg-subtle)]" aria-labelledby="how-heading">
  <div class="container-main">
    <div class="max-w-3xl mb-10">
      <h2 id="how-heading" class="text-3xl font-bold tracking-tight text-[var(--color-text)]">
        How Valetfy works
      </h2>
      <p class="mt-4 text-lg prose-muted">
        Three steps — designed for in-person checkout without a card reader.
      </p>
    </div>

    <ol class="grid gap-6 md:grid-cols-3" role="list">
      {howItWorksSteps.map((item) => (
        <li class="card-premium p-6 md:p-8">
          <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold text-lg mb-4" aria-hidden="true">
            {item.step}
          </span>
          <h3 class="text-xl font-semibold text-[var(--color-text)]">{item.title}</h3>
          <p class="mt-3 prose-muted leading-relaxed">{item.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
