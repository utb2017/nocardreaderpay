---
import { site } from "../data/site";
import { faqItems } from "../data/faq";
import { paymentMethods } from "../data/payment-methods";

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "How to Take Payments Without a Card Reader",
  description: site.description,
  datePublished: "2026-01-01",
  dateModified: "2026-06-27",
  author: {
    "@type": "Organization",
    name: site.brand,
    url: site.valetfyUrl,
  },
  publisher: {
    "@type": "Organization",
    name: site.brand,
    url: site.valetfyUrl,
    logo: {
      "@type": "ImageObject",
      url: `${site.url}/logo.png`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": site.canonical,
  },
  image: `${site.url}/og-image.png`,
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Ways to take payments without a card reader",
  itemListElement: paymentMethods.map((method, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: method.name,
    description: method.summary,
  })),
};

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.brand,
  url: site.valetfyUrl,
  logo: `${site.url}/logo.png`,
  sameAs: [site.valetfyUrl],
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
