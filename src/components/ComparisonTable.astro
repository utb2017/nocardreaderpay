---
import { paymentMethods } from "../data/payment-methods";
---

<section id="comparison" class="section-padding bg-[var(--color-bg-subtle)]" aria-labelledby="comparison-heading">
  <div class="container-main">
    <div class="max-w-3xl mb-10">
      <h2 id="comparison-heading" class="text-3xl font-bold tracking-tight text-[var(--color-text)]">
        Compare payment methods at a glance
      </h2>
      <p class="mt-4 text-lg prose-muted">
        A quick look at hardware, customer friction, and where each option shines.
      </p>
    </div>

    <div class="overflow-x-auto -mx-5 px-5 md:mx-0 md:px-0">
      <table class="w-full min-w-[640px] border-collapse text-left">
        <caption class="sr-only">
          Comparison of ways to take payments without a card reader
        </caption>
        <thead>
          <tr class="border-b-2 border-[var(--color-border-strong)]">
            <th scope="col" class="py-4 pr-4 font-semibold text-[var(--color-text)]">Method</th>
            <th scope="col" class="py-4 px-4 font-semibold text-[var(--color-text)]">Hardware needed?</th>
            <th scope="col" class="py-4 px-4 font-semibold text-[var(--color-text)]">Customer app needed?</th>
            <th scope="col" class="py-4 px-4 font-semibold text-[var(--color-text)]">Accepts all payment types?</th>
            <th scope="col" class="py-4 pl-4 font-semibold text-[var(--color-text)]">Best for</th>
          </tr>
        </thead>
        <tbody>
          {paymentMethods.map((method) => (
            <tr
              class:list={[
                "border-b border-[var(--color-border)]",
                method.featured && "bg-[var(--color-accent-light)] font-medium",
              ]}
            >
              <th scope="row" class="py-4 pr-4 font-semibold text-[var(--color-text)] align-top">
                {method.featured ? (
                  <span>
                    {method.name}
                    <span class="block mt-1 text-xs font-normal text-[var(--color-accent)]">No hardware · No app</span>
                  </span>
                ) : (
                  method.name
                )}
              </th>
              <td class="py-4 px-4 prose-muted align-top">{method.hardware}</td>
              <td class="py-4 px-4 prose-muted align-top">{method.customerApp}</td>
              <td class="py-4 px-4 prose-muted align-top">{method.allPaymentTypes}</td>
              <td class="py-4 pl-4 prose-muted align-top">{method.bestFor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
